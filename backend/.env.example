# Configuración del servidor
PORT=5000
NODE_ENV=development

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin123
DB_NAME=tfg_gestion_ingenieria

# JWT
JWT_SECRET=cambiar_en_produccion
JWT_EXPIRE=24h

# CORS y Frontend (separar múltiples orígenes con coma)
FRONTEND_URL=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Asistente IA
# En local: deja GROQ_API_KEY vacío y asegúrate de tener Ollama corriendo (ollama run phi3:mini)
# En producción (Railway): añade tu clave de Groq (groq.com → API Keys, tier gratuito)
GROQ_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
GROQ_MODEL=llama-3.1-8b-instant
