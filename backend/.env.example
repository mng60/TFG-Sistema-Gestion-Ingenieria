# Configuración del servidor
PORT=5000
NODE_ENV=development

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin123
DB_NAME=tfg_gestion_ingenieria

# JWT
JWT_SECRET=cambiar_en_produccion
JWT_EXPIRE=24h

# CORS y Frontend (separar múltiples orígenes con coma)
FRONTEND_URL=http://localhost:3000,http://localhost:3001,http://localhost:3002

# URLs opcionales para enlaces en correos
PORTAL_URL=http://localhost:3001
ADMIN_URL=http://localhost:3000

# Email opcional
# Si no se configura, el sistema no enviará notificaciones reales
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Cloudinary opcional
# Si no se configura, los archivos se guardan en backend/uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Asistente IA — Groq (gratuito en console.groq.com, 30 RPM, Llama 3.3 70B)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Firebase Admin (push notifications)
# Produccion/Railway: usa estas 3 variables
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Local opcional: tambien puedes usar un JSON de service account
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
