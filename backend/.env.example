# Configuración del servidor
PORT=5000
NODE_ENV=development

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin123
DB_NAME=tfg_gestion_ingenieria

# JWT
JWT_SECRET=cambiar_en_produccion
JWT_EXPIRE=24h

# CORS y Frontend (separar múltiples orígenes con coma)
FRONTEND_URL=http://localhost:3000,http://localhost:3001,http://localhost:3002

# URLs opcionales para enlaces en correos
PORTAL_URL=http://localhost:3001
ADMIN_URL=http://localhost:3000

# Email opcional
# Si no se configura, el sistema no enviará notificaciones reales
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Cloudinary opcional
# Si no se configura, los archivos se guardan en backend/uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Asistente IA
# En local: deja GROQ_API_KEY vacío y usa Ollama
# Si no levantas Ollama, solo quedará limitada la parte del asistente
# En producción (Railway): añade tu clave de Groq
GROQ_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
GROQ_MODEL=llama-3.1-8b-instant
